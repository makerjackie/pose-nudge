{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OnePosture",
  "version": "2.0.1",
  "identifier": "studio.oneapps.oneposture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "OnePosture",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true
      },
      {
        "label": "reminder",
        "url": "index.html?surface=reminder",
        "title": "OnePosture Reminder",
        "width": 420,
        "height": 108,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "shadow": false
      },
      {
        "label": "screen-dim",
        "url": "index.html?surface=dim",
        "title": "OnePosture Screen Reminder",
        "width": 800,
        "height": 600,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; media-src 'self' blob: data: mediastream:; connect-src 'self' ws://localhost:1430 ws://127.0.0.1:1430; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../models",
      "../locales",
      "./icons"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "fs": {},
    "sql": {
      "preload": [
        "sqlite:posture_data.db"
      ]
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4MDU3QTE4OERCQzdEOEEKUldTS2ZieU5HSG9GS0ZNQzJqREhBRDNmNkdzTzVtZkozZEVqU1NvdCtjY2NqczBocTQxMHBsbzIK",
      "endpoints": [
        "https://github.com/makerjackie/pose-nudge/releases/latest/download/latest.json"
      ]
    }
  }
}
